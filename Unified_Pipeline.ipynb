    "log.info(\"Loading DistilBERT sentiment model…\")\n",
    "_sentiment_pipeline = hf_pipeline(\n",
    "    \"sentiment-analysis\",\n",
    "    model=\"distilbert-base-uncased-finetuned-sst-2-english\",\n",
    "    truncation=True,\n",
